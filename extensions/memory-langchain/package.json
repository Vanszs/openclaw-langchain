{
  "name": "@openclaw/memory-langchain",
  "version": "2026.3.14",
  "description": "OpenClaw memory plugin backed by LangChain.js and Chroma",
  "type": "module",
  "dependencies": {
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.34",
    "@langchain/openai": "^1.3.0",
    "@langchain/textsplitters": "^1.0.1",
    "@sinclair/typebox": "0.34.48",
    "chromadb": "^3.4.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@openclaw/memory-langchain",
      "localPath": "extensions/memory-langchain",
      "defaultChoice": "npm"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
